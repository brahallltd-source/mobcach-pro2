generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  username          String             @unique
  passwordHash      String
  /// Optional profile phone (mirrors `Player.phone` when set from profile flows).
  phone             String?
  /// KYC / profile (player self-serve registration & agent application flows).
  country           String?
  city              String?
  dateOfBirth       DateTime?
  /// Player tapped "Become an agent" — admin review queue signal.
  pendingAgentRequest Boolean          @default(false)
  role              String             @default("PLAYER") // PLAYER, AGENT, ADMIN, SUPER_ADMIN
  playerStatus      String?
  assignedAgentId   String?
  agentId           String?
  frozen            Boolean            @default(false)
  /// Suspension (freeze): API returns 403 for agents when `SUSPENDED`. Kept in sync with `frozen` for legacy filters.
  accountStatus     UserAccountStatus  @default(ACTIVE)
  /// Fine-grained admin RBAC (see `lib/permissions.ts`). Empty = no admin capabilities (except SUPER_ADMIN).
  permissions       String[]           @default([])
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  agentApplications AgentApplication[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  player            Player?
  /// Account lifecycle for login/admin (ACTIVE / INACTIVE / BANNED / PENDING_APPROVAL / PENDING_AGENT) — distinct from `accountStatus` suspension.
  status            String             @default("ACTIVE")
  agentProfile      Agent?
  wallet            Wallet?
  /// Wallet recharge requests where this user is the submitting agent (`RechargeRequest.agentId` = `User.id`).
  agentRechargeRequests RechargeRequest[] @relation("RechargeRequestAgentUser")
  balanceLogsAsAdmin    BalanceLog[]        @relation("BalanceLogAdmin")
  balanceLogsAsAgent    BalanceLog[]        @relation("BalanceLogAgent")
  /// Monitoring / manual tags (e.g. HIGH_VALUE). `NEW_AGENT` is also derived at read-time from `createdAt`.
  flags                 String[]            @default([])
  supportTickets        SupportTicket[]     @relation("SupportTicketAgent")
  /// Player → platform support tickets (distinct from agent `SupportTicket`).
  playerSupportTickets  PlayerSupportTicket[]
  /// Soft-removed admin users (cannot sign in; hidden from admin lists).
  deletedAt             DateTime?
  /// Agent onboarding / compliance gate (distinct from `Agent.status` profile row).
  applicationStatus ApplicationStatus @default(NONE)
  hasUsdtAccess       Boolean           @default(false)
  rejectionReason     String?
  transactions        AgentTransaction[]
  /// Player-submitted bank/cash/telecom payment receipts awaiting agent review.
  paymentProofsAsAgent   PaymentProofTransaction[] @relation("PaymentProofAgentUser")
  paymentProofsAsPlayer  PaymentProofTransaction[] @relation("PaymentProofPlayerUser")
  /// Agent-only (role `AGENT`): JSON toggles + detail strings for inbound player payments (CIH, Orange, etc.).
  agentInboundPaymentsJson Json?
  /// Agent-only: human-readable execution window for player-facing UI (e.g. `"15 min"`, `"30 min"`).
  executionTime   String?
  /// Agent-only: enabled payment rails + details for player checkout (`{ id, name, details, isActive }[]`).
  paymentMethods  Json?
  /// Agent marketplace: cumulative thumbs-up from players (`User.role === "AGENT"` rows).
  likes             Int      @default(0)
  /// Agent marketplace: cumulative thumbs-down from players.
  dislikes          Int      @default(0)
  /// Agent-only: unique invite code for `/register?ref=` (e.g. `AGENT-XYZ`).
  inviteCode        String?  @unique
  /// Agent-only: how many milestone bonus blocks (10 players @ 5000 DH each) have been auto-credited to wallet.
  bonusesClaimed    Int      @default(0)
  /// Agent invited by another agent (`User.id` of referrer).
  referredById      String?
  referredBy        User?    @relation("AgentReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  subAgents         User[]   @relation("AgentReferrals")
  /// Bonuses already auto-credited for the sub-agent referral program (blocks of 10 qualified subs @ 10k DH sales).
  agentBonusesPaid  Int      @default(0)
  /// Lifetime sales volume (DH) for this agent user — incremented when they approve player recharge proofs.
  totalSales        Float    @default(0)
  /// Agent (or future roles) presence — updated on login, heartbeat, logout.
  isOnline          Boolean  @default(false)
  lastSeen          DateTime @default(now())
  broadcastsCreated Broadcast[] @relation("BroadcastCreatedBy")
  /// Latest Web Push `PushSubscription` JSON for this user (single device; replace on re-subscribe).
  pushSubscription  Json?

  @@index([deletedAt])
  @@index([referredById])
}

/// Singleton row `id = "default"` — global platform knobs (admin-editable).
model SystemSettings {
  id              String   @id @default("default")
  bonusPercentage Float    @default(10)
  /// Minimum DH for agent → treasury wallet recharge requests (admin-editable).
  minRechargeAmount   Float   @default(1000)
  /// When false, invitation milestone DH cannot be merged into recharge requests (UI + API).
  affiliateBonusEnabled Boolean @default(true)
  /// Max DH per player profit-withdrawal request (admin-editable; enforced on submission).
  maxWithdrawalAmount Float @default(100000)
  /// Display / treasury hint: 1 USDT ≈ this many MAD (super-admin editable from command center).
  usdtToMadRate   Float    @default(10.5)
  isMaintenance   Boolean  @default(false)
  announcement    String?
  platformName    String   @default("GS365Cash")
  primaryColor    String   @default("#0f172a")
  logoUrl         String?
  faviconUrl      String?
  /// PWA install icon (PNG, 192×192). URL or site path (e.g. `/icon-192x192.png`).
  pwaIcon192      String?
  /// PWA splash / maskable-friendly icon (PNG, 512×512).
  pwaIcon512      String?
  /// PWA manifest `theme_color` (e.g. mobile status bar).
  pwaThemeColor   String   @default("#0f172a")
  /// PWA manifest `background_color` (splash while loading).
  pwaBgColor      String   @default("#0f172a")
  updatedAt       DateTime @updatedAt
}

/// Admin-published global message shown to players and agents (at most one active row).
model Broadcast {
  id              String   @id @default(uuid())
  message         String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  createdByUserId String?
  createdBy       User?    @relation("BroadcastCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([isActive, createdAt(sort: Desc)])
}

/// Singleton row `id = 1` — public contact / social branding (super-admin editable).
model BrandingSettings {
  id         Int      @id @default(1)
  facebook   String?
  instagram  String?
  telegram   String?
  gmail      String?
  websiteUrl String   @default("https://gosport365.com")
  showFb     Boolean  @default(true)
  showInsta  Boolean  @default(true)
  showTele   Boolean  @default(true)
  updatedAt  DateTime @updatedAt
}

/// Admin manual wallet adjustments (audit trail).
model BalanceLog {
  id               String   @id @default(uuid())
  adminId          String
  agentId          String
  type             String   @default("MANUAL_ADJUST")
  amount           Float
  operation        String
  bonusApplied     Boolean  @default(false)
  previousBalance  Float
  newBalance       Float
  createdAt        DateTime @default(now())
  admin            User     @relation("BalanceLogAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  agent            User     @relation("BalanceLogAgent", fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, createdAt])
}

model AgentApplication {
  id        String   @id @default(uuid())
  userId    String
  fullName  String
  username  String
  email     String
  phone     String
  country   String?
  city      String?
  birthDate DateTime?
  note      String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@index([status])
}

model Player {
  id              String       @id @default(uuid())
  userId          String       @unique
  firstName       String
  lastName        String
  username        String       @unique
  phone           String
  city            String?
  country         String?
  dateOfBirth     String?
  status          String
  /// GoSport365 login set by the agent after manual approval (plain username; password stored bcrypt).
  gosportUsername String?      @map("gosport_username")
  gosportPassword String?      @map("gosport_password")
  assignedAgentId String?
  referredBy      String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  orders          Order[]
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  withdrawals     Withdrawal[]
  agentCustomers  AgentCustomer[]
}

/// Players saved on an agent’s personal list (distinct from `Player.assignedAgentId` alone).
model AgentCustomer {
  id         String   @id @default(uuid())
  agentId    String
  playerId   String
  isFlagged  Boolean  @default(false)
  /// GoSport365 / GS365Cash login after approval (`gs365Username` plain; `gs365Password` stores bcrypt hash only).
  gs365Username String?
  /// Bcrypt hash of the player’s GS365 password (column name legacy in DB).
  gs365Password String? @map("gs365PasswordHash")
  /// Minutes promised for execution (e.g. 15, 30, 60); overrides agent default when set.
  executionTimeMinutes Int?
  /// Link lifecycle: REQUESTED (invite, awaiting agent) | PENDING (legacy) | CONNECTED | APPROVED (legacy).
  status     String   @default("REQUESTED") @map("approvalStatus")
  /// Lifetime amount recharged by this player through this agent (approved proof flows).
  totalRecharged Float @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([agentId, playerId])
  @@index([agentId])
  @@index([playerId])
  @@index([status])
}

model Agent {
  id               String             @id @default(uuid())
  fullName         String
  username         String             @unique
  email            String             @unique
  phone            String
  country          String?
  status           String             @default("ACTIVE")
  referralCode     String?            @unique
  online           Boolean            @default(false)
  note             String?
  responseMinutes  Int                @default(30)
  /// Default order execution window (minutes) for new player links; shown in agent payment settings.
  defaultExecutionTimeMinutes Int       @default(30)
  rating           Float              @default(0)
  successRate      Float              @default(0)
  tradesCount      Int                @default(0)
  availableBalance Float              @default(0)
  verified         Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  activations      Activation[]
  bonusProfile     AgentBonusProfile?
  orders           Order[]
  paymentMethods   PaymentMethod[]
  wallet           Wallet?
  userId           String             @unique
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentCustomers   AgentCustomer[]
}

model WinnerRequest {
  id          String   @id @default(uuid())
  playerEmail String
  agentId     String
  amount      Float
  note        String?
  status      String   @default("pending") // pending, approved, rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([agentId])
  @@index([playerEmail])
}

model Order {
  id                String         @id @default(uuid())
  agentId           String
  playerId          String?
  playerEmail       String
  amount            Float
  gosportUsername   String
  status            String
  paymentMethodName String?
  proofUrl          String?
  proofHash         String?
  reviewRequired    Boolean        @default(false)
  reviewReason      String?
  walletDeducted    Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  systemThread      Boolean        @default(false)
  fraudFlags        FraudFlag[]
  agent             Agent          @relation(fields: [agentId], references: [id])
  player            Player?        @relation(fields: [playerId], references: [id])
  messages          OrderMessage[]
  disputes          Dispute[]
}

model OrderMessage {
  id         String   @id @default(uuid())
  orderId    String
  senderRole String
  message    String
  createdAt  DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Wallet {
  id        String         @id @default(uuid())
  agentId   String?        @unique
  balance   Float          @default(0)
  updatedAt DateTime       @updatedAt
  agent     Agent?         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  userId    String         @unique
  user      User           @relation(fields: [userId], references: [id])
  ledger    WalletLedger[]
}

model WalletLedger {
  id        String   @id @default(uuid())
  agentId   String
  type      String
  amount    Float
  reason    String
  meta      Json?
  createdAt DateTime @default(now())
  walletId  String
  wallet    Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

/// Platform payment details: either global admin treasury (`ownerRole: "ADMIN"`, `agentId` null — not an Agent profile)
/// or an agent’s own methods (`ownerRole: "agent"`, `agentId` set).
model PaymentMethod {
  id            String              @id @default(uuid())
  ownerRole     String
  ownerId       String
  type          PaymentMethodType
  methodName    String
  currency      String
  accountName   String?
  rib           String?
  walletAddress String?
  network       String?
  phone         String?
  feePercent    Float             @default(0)
  active        Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  /// Null for global admin treasury; set only for methods owned by an `Agent` profile.
  agentId       String?
  agent         Agent?            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  provider      String? // 🟢 زدنا المزود (خاص بـ Cash)
  instructions  String?           @db.Text // 🟢 زدنا التعليمات (مساحة كبيرة للكتابة)
  rechargeRequests RechargeRequest[]
}

model Activation {
  id            String    @id @default(uuid())
  agentId       String
  playerUserId  String
  playerEmail   String
  username      String
  passwordPlain String
  whatsapp      String?
  status        String
  messageText   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  activatedAt   DateTime?
  sentAt        DateTime?
  agent         Agent     @relation(fields: [agentId], references: [id])
}

model AgentBonusProfile {
  id              String    @id @default(uuid())
  agentId         String    @unique
  volume          Float     @default(0)
  energy          Float     @default(0)
  completedOrders Int       @default(0)
  bonusBalance    Float     @default(0)
  pendingBonus    Float     @default(0)
  lastOrderAt     DateTime?
  updatedAt       DateTime  @updatedAt
  agent           Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model PendingBonus {
  id        String       @id @default(uuid())
  agentId   String
  source    String
  sourceRef String
  amount    Float
  status    RewardStatus
  meta      Json?
  createdAt DateTime     @default(now())
  appliedAt DateTime?
}

model Referral {
  id                String   @id @default(uuid())
  playerUserId      String   @unique
  playerEmail       String
  referredByAgentId String
  firstOrderReward  Float    @default(0)
  rewardStatus      String
  rewardedOrderId   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// In-app row: recipient `userId`, optional legacy `targetRole`/`targetId` for chat-style polling.
/// Boolean `read` is returned as `isRead` from `GET /api/notifications?for=me`.
model Notification {
  id         String           @id @default(uuid())
  userId     String?
  targetRole String
  targetId   String
  title      String
  message    String
  type       NotificationType @default(INFO)
  link       String?
  /// Unread until marked read; exposed as `isRead` on `GET /api/notifications?for=me`.
  read       Boolean          @default(false)
  createdAt  DateTime         @default(now())
  user       User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model Withdrawal {
  id              String           @id @default(uuid())
  playerId        String
  playerEmail     String
  agentId         String?
  amount          Float
  method          String
  status          WithdrawalStatus
  rib             String?
  swift           String?
  cashProvider    String?
  fullName        String?
  phone           String?
  city            String?
  txHash          String?
  proofUrl        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  kind            String           @default("standard")
  gosportUsername String?
  winnerOrderId   String?
  adminNote       String?
  player          Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model FraudFlag {
  id        String   @id @default(uuid())
  orderId   String
  type      String
  score     Int      @default(0)
  note      String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  meta       Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
}

model EscrowStub {
  id        String   @id @default(uuid())
  orderId   String
  state     String
  createdAt DateTime @default(now())
}

/// Agent-submitted treasury top-up (bank / wallet / crypto proof) — distinct from wallet `RechargeRequest`.
model AgentTransaction {
  id          String            @id @default(cuid())
  agentId     String
  agent       User              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  amount      Float
  method      String // e.g. "CIH", "ORANGE_MONEY", "SKRILL"
  status      TransactionStatus @default(PENDING)
  details     Json // { rib: "..." } or { phone: "..." }
  receiptUrl  String
  motif       String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([agentId, createdAt])
}

model RechargeRequest {
  id                  String          @id
  agentId             String
  agentEmail          String
  /// Submitting user (`User.id` === `agentId`); nested `agentProfile` is the public `Agent` row when present.
  agent                 User            @relation("RechargeRequestAgentUser", fields: [agentId], references: [id], onDelete: Cascade)
  amount              Float
  adminMethodId       String
  adminMethodName     String
  paymentMethodId     String?
  paymentMethod       PaymentMethod?  @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  txHash              String?
  proofUrl            String?
  note                String?
  status              String
  bonusAmount         Float           @default(0)
  pendingBonusApplied Float           @default(0)
  gosport365Username  String?
  /// Monitoring flags, e.g. HIGH_VALUE, NEW_AGENT (computed on create / merged in admin APIs).
  flags               String[]        @default([])
  createdAt           DateTime        @default(now())
  updatedAt           DateTime

  @@index([paymentMethodId])
  @@index([agentId])
}

model SupportTicket {
  id              String              @id @default(uuid())
  agentId         String
  subject         String
  message         String              @db.Text
  status          SupportTicketStatus @default(OPEN)
  adminReply      String?             @db.Text
  isReadByAdmin   Boolean             @default(false)
  isReadByAgent   Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  agent           User                @relation("SupportTicketAgent", fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, createdAt])
  @@index([status, createdAt])
}

/// Player inquiries to the platform team (separate from agent `SupportTicket` inbox).
model PlayerSupportTicket {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   String
  message   String   @db.Text
  /// OPEN | IN_PROGRESS | RESOLVED
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("player_support_tickets")
}

model Complaint {
  id          String   @id @default(uuid())
  playerEmail String
  subject     String
  message     String
  adminReply  String?
  status      String   @default("pending") // pending, resolved
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Dispute {
  id          String   @id @default(uuid())
  orderId     String
  playerEmail String
  reason      String?
  adminNote   String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

enum UserRole {
  ADMIN
  AGENT
  PLAYER
}

enum UserAccountStatus {
  ACTIVE
  SUSPENDED
}

enum ApplicationStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

/// Player → agent payment proof lifecycle (distinct from `AgentTransaction` treasury proofs).
/// `status` values are defined in `lib/recharge-proof-lifecycle.ts` (stored as plain string for DB portability).

model PaymentProofTransaction {
  id                 String    @id @default(uuid())
  amount             Float
  senderName         String
  senderPhone        String?
  receiptUrl         String
  /// PENDING_PROOF | PROCESSING | AGENT_APPROVED | AGENT_REJECTED | PLAYER_CONFIRMED | DISPUTED
  status             String    @default("PROCESSING")
  paymentMethodId    String?
  paymentMethodTitle String?
  /// Human-readable method snapshot for admin / history.
  paymentMethod      String?
  /// Agent rejection note (required when status = AGENT_REJECTED).
  agentRejectReason  String?   @map("rejectReason")
  playerComment      String?   @db.Text
  /// True = like, false = dislike (after PLAYER_CONFIRMED feedback).
  playerRating       Boolean?
  /// Player text when opening a dispute (status DISPUTED).
  disputeMessage     String?   @db.Text
  timerStartedAt     DateTime?
  isLatePenaltyApplied Boolean @default(false)

  agentUserId   String
  playerUserId  String
  agentUser     User @relation("PaymentProofAgentUser", fields: [agentUserId], references: [id], onDelete: Cascade)
  playerUser    User @relation("PaymentProofPlayerUser", fields: [playerUserId], references: [id], onDelete: Cascade)

  /// Resolution chat (`transactionId` on `Message` = this row’s `id`).
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentUserId, status, createdAt])
  @@index([playerUserId, createdAt])
  @@map("payment_proof_transactions")
}

/// Chat messages for a payment-proof transaction (`PaymentProofTransaction.id` = `transactionId`).
model Message {
  id              String                  @id @default(cuid())
  transactionId   String
  transaction     PaymentProofTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  senderId        String
  senderRole      String
  content         String                  @db.Text
  isRead          Boolean                 @default(false)
  createdAt       DateTime                @default(now())

  @@index([transactionId, createdAt])
}

enum SupportTicketStatus {
  OPEN
  CLOSED
}

enum OrderStatus {
  pending_payment
  proof_uploaded
  flagged_for_review
  agent_approved_waiting_player
  completed
  cancelled
  linked_waiting_first_order
}

enum WithdrawalStatus {
  pending
  sent
  completed
  rejected
}

enum RewardStatus {
  locked
  ready
  claimed
  pending
  applied
}

enum PaymentMethodType {
  bank
  cash
  crypto
}

enum NotificationType {
  INFO
  RECHARGE_REQUEST
  SUCCESS
  ALERT
}

enum Status {
  pending
  approved
  rejected
  linked_waiting_first_order
  completed
  cancelled
}
